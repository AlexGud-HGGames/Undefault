{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Spotify": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://127.0.0.1:5292/callback",
    "Scopes": [
      "user-modify-playback-state",
      "user-read-playback-state"
    ]
  },
  "Gsi": {
    "Method": "POST",
    "Path": "/gsi",
    "Url": "http://127.0.0.1:5292",
    "AllowReset": true
  },
  "UseMockSpotify": false,
  "Runtime": {
    "Mode": "scenario_playback"
  },
  "EventDetector": {
    "EnableRoundStart": true,
    "EnableDeath": true,
    "EnableCombat": false,
    "EnableIdle": false,
    "RoundStartPhase": "live",
    "DeathCooldown": "00:00:01"
  },
  "SpotifyVolumeDuck": {
    "MuteVolume": 0,
    "FallbackRestoreVolume": 50
  },
  "SmartTrackStart": {
    "Enabled": false,
    "PreloadOnStartup": true
  },
  "Timeline": {
    "MaxInMemoryEntries": 1000,
    "Directory": "timeline",
    "EpisodeBeforeEntryCount": 10,
    "EpisodeAfterEntryCount": 5
  },
  "ManualMusicActions": {
    "AllowedEventKeys": [],
    "CommandMappings": [
      {
        "EventKey": "custom:music_mute",
        "Command": "duck",
        "VolumePercent": 0
      },
      {
        "EventKey": "custom:music_pause",
        "Command": "pause"
      },
      {
        "EventKey": "custom:music_resume",
        "Command": "resume"
      },
      {
        "EventKey": "custom:music_restore",
        "Command": "restore_volume"
      }
    ]
  },
  "Keybinds": {
    "Bindings": [
      {
        "Key": "Ctrl+Alt+M",
        "EventKey": "custom:music_mute",
        "Action": "duck",
        "Detail": "manual mute hotkey"
      },
      {
        "Key": "Ctrl+Alt+P",
        "EventKey": "custom:music_pause",
        "Action": "pause",
        "Detail": "manual pause hotkey"
      },
      {
        "Key": "Ctrl+Alt+R",
        "EventKey": "custom:music_resume",
        "Action": "resume",
        "Detail": "manual resume hotkey"
      }
    ]
  },
  "RulesEngine": {
    "ActionMap": {
      "round_start": [ "spotify.control_profile" ],
      "death": [ "spotify.control_profile" ]
    }
  }
}
