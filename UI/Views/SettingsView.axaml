<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="16">
            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Tomato" />

            <StackPanel Spacing="6">
                <TextBlock Text="GSI Endpoint" FontWeight="SemiBold" />
                <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBox Text="{Binding GsiEndpoint}" IsReadOnly="True" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Copy" Command="{Binding CopyEndpointCommand}" />
                            <Button Content="Open" Command="{Binding OpenEndpointCommand}" />
                        </StackPanel>
                        <TextBlock Text="Place gamestate_integration_*.cfg into CS2/Dota cfg folder." Opacity="0.7" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Rules: Action Map" FontWeight="SemiBold" />
                <TextBlock Text="{Binding AvailableActionKeysHint}" Opacity="0.7" />
                <ItemsControl ItemsSource="{Binding EventSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EventSettingsViewModel">
                            <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,6">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding ActionKeys}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:EditableStringItem">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBox Width="260" Text="{Binding Value}" />
                                                    <Button Content="Remove" Command="{Binding RemoveCommand}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="Add action" Command="{Binding AddActionKeyCommand}" Width="120" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Spotify: Event Playlists" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding EventSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EventSettingsViewModel">
                            <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,6">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding PlaylistUris}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:EditableStringItem">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBox Width="360" Text="{Binding Value}" />
                                                    <Button Content="Remove" Command="{Binding RemoveCommand}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="Add playlist URI" Command="{Binding AddPlaylistUriCommand}" Width="160" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Spotify: Default Playlists" FontWeight="SemiBold" />
                <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <ItemsControl ItemsSource="{Binding DefaultPlaylistUris}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EditableStringItem">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBox Width="360" Text="{Binding Value}" />
                                        <Button Content="Remove" Command="{Binding RemoveCommand}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Add default playlist" Command="{Binding AddDefaultPlaylistCommand}" Width="180" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Spotify Authorization" FontWeight="SemiBold" />
                <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding SpotifyAuthStatus}" />
                        <TextBlock Text="{Binding SpotifyPlaybackState}" Opacity="0.7" />
                        <Button Content="Connect Spotify" Command="{Binding ConnectSpotifyCommand}" Width="180" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Reload" Command="{Binding ReloadCommand}" Width="120" />
                <Button Content="Save" Command="{Binding SaveCommand}" Width="120" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
