<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.StatusView"
             x:DataType="vm:StatusViewModel">
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="16">
            <TextBlock Text="Status" FontSize="20" FontWeight="SemiBold" />

            <StackPanel Spacing="6">
                <TextBlock Text="GSI" FontWeight="SemiBold" />
                <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                        <TextBlock Text="Connection" Grid.Row="0" />
                        <TextBlock Text="{Binding GsiStatus}" Grid.Row="0" Grid.Column="1" />

                        <TextBlock Text="Last snapshot" Grid.Row="1" />
                        <TextBlock Text="{Binding LastSnapshotTime}" Grid.Row="1" Grid.Column="1" />

                        <TextBlock Text="Game" Grid.Row="2" />
                        <TextBlock Text="{Binding Game}" Grid.Row="2" Grid.Column="1" />

                        <TextBlock Text="Last event" Grid.Row="3" />
                        <TextBlock Text="{Binding LastEvent}" Grid.Row="3" Grid.Column="1" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Spotify" FontWeight="SemiBold" />
                <Border BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4" Padding="12">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                        <TextBlock Text="Connection" Grid.Row="0" />
                        <TextBlock Text="{Binding SpotifyStatus}" Grid.Row="0" Grid.Column="1" />

                        <TextBlock Text="Playback" Grid.Row="1" />
                        <TextBlock Text="{Binding PlaybackState}" Grid.Row="1" Grid.Column="1" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
