<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.LogsView"
             x:DataType="vm:LogsViewModel">
    <Grid RowDefinitions="Auto,*" Margin="16">
        <TextBlock Text="Logs" FontSize="20" FontWeight="SemiBold" />
        <Border Grid.Row="1" Margin="0,12,0,0" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="LogsList" ItemsSource="{Binding Logs}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" Margin="8,4">
                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Opacity="0.7" />
                            <TextBlock Text="{Binding EventType}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{Binding Message}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
