<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:UI.Views"
        xmlns:vm="clr-namespace:UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="620"
        x:Class="UI.MainWindow"
        Title="UndefaultIt"
        Width="980"
        Height="620"
        x:DataType="vm:MainWindowViewModel">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <TabControl TabStripPlacement="Left">
        <TabItem Header="Status">
            <views:StatusView DataContext="{Binding Status}" />
        </TabItem>
        <TabItem Header="Settings">
            <views:SettingsView DataContext="{Binding Settings}" />
        </TabItem>
        <TabItem Header="Logs">
            <views:LogsView DataContext="{Binding Logs}" />
        </TabItem>
    </TabControl>
</Window>
